# Database (PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ordersystem
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# RabbitMQ
SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest

# Security
JWT_SECRET_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
SECURITY_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
SECURITY_CORS_ALLOWED_ORIGINS=http://localhost:3001

# Observability - Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Observability - Application
SPRING_PROFILES_ACTIVE=docker
LOG_LEVEL=INFO
WEB_LOG_LEVEL=WARN
SQL_LOG_LEVEL=WARN

# Metrics & Monitoring
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus
MANAGEMENT_METRICS_EXPORT_PROMETHEUS_ENABLED=true
