# Database (PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ordersystem
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# RabbitMQ
SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest
OUTBOX_ENABLED=true
OUTBOX_BATCH_SIZE=50
OUTBOX_FIXED_DELAY=5000
PAYMENT_GATEWAY_ENABLED=true
PAYMENT_GATEWAY_BASE_URL=http://localhost:8089
PAYMENT_GATEWAY_API_KEY=demo-portfolio-key

# Security
JWT_SECRET_KEY=
SECURITY_SECRET=
SECURITY_CORS_ALLOWED_ORIGINS=http://localhost:4200
SECURITY_BOOTSTRAP_ADMIN_ENABLED=true
SECURITY_BOOTSTRAP_ADMIN_USERNAME=admin
SECURITY_BOOTSTRAP_ADMIN_PASSWORD=change-this-admin-password
SECURITY_BOOTSTRAP_ADMIN_EMAIL=admin@local.orderflow

# Observability - Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Observability - Application
SPRING_PROFILES_ACTIVE=docker
LOG_LEVEL=INFO
WEB_LOG_LEVEL=WARN
SQL_LOG_LEVEL=WARN
REDIS_ENABLED=true
CACHE_TYPE=redis
CACHE_TTL=1h
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Metrics & Monitoring
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus
MANAGEMENT_METRICS_EXPORT_PROMETHEUS_ENABLED=true
